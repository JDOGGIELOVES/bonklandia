# ── Shared treasury (Bonklandia · Bonk Miner · GrokSight · bonklandia.com) ──
# Sync from Bonk Miner:  node scripts/sync-bonk-miner-treasury.mjs
# Or export key:         cd bonga-bonk-miner && npm run treasury:export-key

NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# NEXT_PUBLIC_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY

NEXT_PUBLIC_TREASURY_PUBLIC_KEY=8w1KpwzpAttJAonNHohTyAhzcw4iYuCrQPhppPRw5ASb
TREASURY_PUBLIC_KEY=8w1KpwzpAttJAonNHohTyAhzcw4iYuCrQPhppPRw5ASb

# Server-only signing key — same as BONGA_TREASURY_SECRET_KEY on GrokSight (Sensitive)
# Signs SPL token payouts. Pays base network fee only (~5_000 lamports); never SOL transfers.
BONGA_TREASURY_SECRET_KEY=
# Bonklandia also accepts:
# TREASURY_PRIVATE_KEY=
# TREASURY_SECRET_KEY=

# HMAC for casino session tokens (use a long random string in production)
# CASINO_SESSION_SECRET=

# ── EMERGENCY KILL SWITCH ──────────────────────────────────────────────────
# Set to true to immediately stop cashier, casino sessions, chip claims, and paid spins.
# Aliases: BONGA_EMERGENCY_STOP=true  or  KILL_SWITCH=true
# Optional custom message: EMERGENCY_STOP_MESSAGE=We are pausing play — back soon.
# EMERGENCY_STOP=true

# Optional finer-grained pauses (cashier only — use EMERGENCY_STOP to halt everything)
# CLAIMS_PAUSED=true
# CASHIER_PAYOUTS_ENABLED=false
# MAX_EXCHANGES_PER_WALLET_PER_DAY=20
# TREASURY_VELOCITY_MAX_PAYOUTS=50